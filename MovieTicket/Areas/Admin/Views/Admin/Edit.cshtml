@model MovieTicket.Models.Movie

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Movie";
}

<style>
    .edit-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .poster-preview {
        width: 180px;
        height: 250px;
        object-fit: cover;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
    }

    textarea.form-control {
        resize: none;
    }

    .btn-save {
        background: #111827;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-weight: 600;
    }

        .btn-save:hover {
            background: #1f2937;
            color: white;
        }
</style>

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1">
                ✏️ Edit Movie
            </h3>

            <p class="text-muted mb-0">
                Update movie information
            </p>
        </div>

        <a href="/Admin/Admin/Movies"
           class="btn btn-light border rounded-3 px-4">

            ← Back

        </a>

    </div>

    <div class="edit-card p-4">

        <form action="/Admin/Admin/Edit"
              method="post"
              enctype="multipart/form-data">

            <!-- hidden id -->
            <input type="hidden"
                   name="Id"
                   value="@Model.Id" />

            <div class="row g-4">

                <!-- LEFT -->
                <div class="col-lg-4">

                    <label class="form-label fw-semibold mb-3">
                        Current Poster
                    </label>

                    <div>
                        <img src="~/img/@Model.Image"
                             class="poster-preview"
                             alt="@Model.Title">
                    </div>

                    <div class="mt-4">

                        <label class="form-label">
                            Upload New Poster
                        </label>

                        <input type="file"
                               name="ImageFile"
                               class="form-control" />

                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-lg-8">

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Movie Title
                        </label>

                        <input type="text"
                               name="Title"
                               value="@Model.Title"
                               class="form-control"
                               required />

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label class="form-label fw-semibold">
                                Duration (minutes)
                            </label>

                            <input type="number"
                                   name="Duration"
                                   value="@Model.Duration"
                                   class="form-control"
                                   required />

                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Rating
                            </label>

                            <input type="number"
                                   step="0.1"
                                   min="0"
                                   max="10"
                                   name="Rating"
                                   value="@Model.Rating"
                                   class="form-control rounded-3"
                                   placeholder="VD: 8.7"
                                   required />

                            <small class="text-muted">
                                Rating từ 0 → 10
                            </small>    

                    </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Release Date
                            </label>

                            <input type="date"
                                   name="ReleaseDate"
                                   value="@Model.ReleaseDate?.ToString("yyyy-MM-dd")"
                                   class="form-control rounded-3"
                                   required />
                        </div>

                    <div class="mb-4">

                        <label class="form-label fw-semibold">
                            Description
                        </label>

                        <textarea name="Description"
                                  rows="7"
                                  class="form-control">@Model.Description</textarea>

                    </div>

                    <button type="submit"
                            class="btn btn-save">

                        💾 Save Changes

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>
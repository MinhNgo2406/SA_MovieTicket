@model MovieTicket.Models.Showtime

@{
    Layout = "_AdminLayout";

    var movies = ViewBag.Movies as List<MovieTicket.Models.Movie>;
    var rooms = ViewBag.Rooms as List<MovieTicket.Models.Room>;
}

<div class="card p-4 shadow-sm border-0 rounded-4">

    <h3 class="fw-bold mb-4">
        ✏️ Edit Showtime
    </h3>

    <form asp-action="EditShowtime" method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">

            <label class="form-label">
                Movie
            </label>

            <select name="MovieId"
                    class="form-select">

                @foreach (var movie in movies)
                {
                    if (movie.Id == Model.MovieId)
                    {
                        <option value="@movie.Id" selected>
                            @movie.Title
                        </option>
                    }
                    else
                    {
                        <option value="@movie.Id">
                            @movie.Title
                        </option>
                    }
                }

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label">
                Room
            </label>

            <select name="RoomId" class="form-select">

                @foreach (var room in rooms)
                {
                    if (room.Id == Model.RoomId)
                    {
                        <option value="@room.Id" selected>
                            @room.Name
                        </option>
                    }
                    else
                    {
                        <option value="@room.Id">
                            @room.Name
                        </option>
                    }
                }

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label">
                Start Time
            </label>

            <input type="datetime-local"
                   name="StartTime"
                   value="@(Model.StartTime.HasValue
                               ? Model.StartTime.Value.ToString("yyyy-MM-ddTHH:mm")
                               : "")"
                   class="form-control" />


        </div>

        <div class="mb-3">

            <label class="form-label">
                End Time
            </label>

            <input type="datetime-local"
                   name="EndTime"
                   value="@(Model.EndTime.HasValue
                               ? Model.EndTime.Value.ToString("yyyy-MM-ddTHH:mm")
                               : "")"
                   class="form-control" />

        </div>

        <button type="submit"
                class="btn btn-primary">

            Save Changes

        </button>

    </form>

</div>
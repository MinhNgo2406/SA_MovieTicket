@model MovieTicket.Models.Order

<!-- Thêm Font Awesome để có Icon đẹp -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <!-- Tiêu đề -->
            <div class="text-center mb-4">
                <h2 class="fw-extrabold text-uppercase letter-spacing-1">
                    <i class="fa-solid fa-credit-card me-2 text-primary"></i>Thanh Toán
                </h2>
                <p class="text-muted">Vui lòng kiểm tra lại thông tin đơn hàng trước khi thanh toán</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Header của Card -->
                <div class="bg-dark p-3 text-center">
                    <span class="text-white-50 small text-uppercase">Mã đơn hàng</span>
                    <h4 class="text-white mb-0">#@Model.Id</h4>
                </div>

                <div class="card-body p-4">
                    <!-- Chi tiết số tiền -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Trạng thái:</span>
                        <span class="badge @(Model.Status == "Pending" ? "bg-warning text-dark" : "bg-success") rounded-pill px-3">
                            @Model.Status
                        </span>
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="py-3 text-center">
                        <span class="text-muted d-block mb-1">Tổng số tiền cần thanh toán</span>
                        <h1 class="display-5 fw-bold text-danger">
                            @string.Format("{0:N0}", Model.TotalAmount) <small class="fs-4">VNĐ</small>
                        </h1>
                    </div>

                    <hr class="text-muted opacity-25">

                    <!-- Lựa chọn phương thức (Giả lập để nhìn cho chuyên nghiệp) -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase text-muted">Phương thức thanh toán</label>
                        <div class="border rounded-3 p-3 d-flex align-items-center bg-light">
                            <i class="fa-solid fa-wallet text-primary fs-4 me-3"></i>
                            <div>
                                <p class="mb-0 fw-bold">Ví điện tử / Thẻ nội địa</p>
                                <small class="text-muted">An toàn & Bảo mật 100%</small>
                            </div>
                            <i class="fa-solid fa-circle-check ms-auto text-success"></i>
                        </div>
                    </div>

                    <!-- Nút bấm -->
                    <form method="post" asp-action="Pay" asp-controller="Payment">
                        <input type="hidden" name="orderId" value="@Model.Id" />

                        <button type="submit" class="btn btn-primary btn-lg w-100 py-3 rounded-3 fw-bold shadow-sm transition-all hover-lift">
                            XÁC NHẬN THANH TOÁN <i class="fa-solid fa-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <a href="/" class="text-decoration-none small text-muted hover-dark">
                            <i class="fa-solid fa-chevron-left me-1"></i> Quay lại trang chủ
                        </a>
                    </div>
                </div>
            </div>

            <!-- Footer an tâm -->
            <div class="text-center mt-4 text-muted small">
                <i class="fa-solid fa-shield-halved me-1"></i> Giao dịch được mã hóa bởi SSL bảo mật
            </div>

        </div>
    </div>
</div>

<style>
    /* Một chút CSS để làm mượt giao diện */
    .fw-extrabold { font-weight: 800; }
    .letter-spacing-1 { letter-spacing: 1px; }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .transition-all { transition: all 0.3s ease; }
    .hover-dark:hover { color: #212529 !important; }
</style>
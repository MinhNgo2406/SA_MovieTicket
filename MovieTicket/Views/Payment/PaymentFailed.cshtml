@{
    // Tắt Layout chung để form đứng độc lập giữa màn hình
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Failed - MovieHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

    <style>
        .error-card {
            max-width: 450px;
            width: 100%;
        }

        /* Biểu tượng lỗi màu đỏ nhạt */
        .error-icon-wrapper {
            width: 75px;
            height: 75px;
            background-color: #fee2e2; /* Màu đỏ nhạt */
            color: #ef4444; /* Màu đỏ đậm cho dấu X */
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            margin: 0 auto 20px auto;
        }

        /* Nút màu đen đậm */
        .btn-dark-custom {
            background-color: #111827;
            color: white;
            border: none;
            font-weight: 500;
        }

            .btn-dark-custom:hover {
                background-color: #1f2937;
                color: white;
            }

        /* Nút viền xám */
        .btn-outline-custom {
            background-color: white;
            border: 1px solid #d1d5db;
            color: #374151;
            font-weight: 500;
        }

            .btn-outline-custom:hover {
                background-color: #f3f4f6;
                color: #111827;
            }
    </style>
</head>
<body>

    <div class="card error-card border-0 shadow-sm p-4 p-md-5 rounded-4 text-center">

        <div class="error-icon-wrapper">
            <i class="bi bi-x-lg"></i>
        </div>

        <h4 class="fw-medium mb-3" style="font-size: 1.4rem;">Transaction Unsuccessful</h4>
        <p class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">
            We encountered an error while processing your payment. Your selected seats have been released.
        </p>

        <div class="d-flex flex-column gap-3 mb-4">
            <a asp-controller="Seat" asp-action="SeatSelection" class="btn btn-dark-custom py-3 rounded-3">
                Try Payment Again
            </a>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-custom py-3 rounded-3">
                Return to Movie List
            </a>
        </div>

        <hr class="text-muted opacity-25 mb-4">
        <p class="text-muted mb-0" style="font-size: 0.85rem;">
            Need help? Contact our support team
        </p>

    </div>

</body>
</html>

@model MovieTicket.Models.Order

<!-- Thêm Font Awesome & Animate.css để tăng hiệu ứng -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5 text-center">

            <!-- Icon thành công với hiệu ứng ZoomIn -->
            <div class="animate__animated animate__zoomIn">
                <div class="display-1 text-success mb-2">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <h1 class="fw-extrabold text-dark animate__animated animate__fadeInUp animate__delay-1s">
                    Thanh Toán Thành Công!
                </h1>
                <p class="text-muted animate__animated animate__fadeInUp animate__delay-1s">
                    Cảm ơn bạn đã tin tưởng lựa chọn dịch vụ của chúng tôi.
                </p>
            </div>

            <!-- "Tấm vé" hóa đơn -->
            <div class="card border-0 shadow-lg rounded-4 mt-4 animate__animated animate__fadeInUp animate__delay-1s">
                <div class="card-body p-4 p-md-5">

                    <div class="receipt-dashed-line mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Mã đơn hàng:</span>
                            <span class="fw-bold">#@Model.Id</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Ngày thanh toán:</span>
                            <span class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Trạng thái:</span>
                            <span class="text-success fw-bold">Hoàn tất <i class="fa-solid fa-check-double small"></i></span>
                        </div>
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <span class="text-muted small d-block mb-1">Số tiền đã thanh toán</span>
                        <h2 class="text-primary fw-bold mb-0">
                            @string.Format("{0:N0}", Model.TotalAmount) <small class="fs-6 text-muted">VNĐ</small>
                        </h2>
                    </div>

                    <div class="row g-2">
                        <div class="col-6">
                            <button onclick="window.print()" class="btn btn-outline-secondary w-100 py-2 rounded-3">
                                <i class="fa-solid fa-print me-1"></i> In hóa đơn
                            </button>
                        </div>
                        <div class="col-6">
                            <a href="/" class="btn btn-dark w-100 py-2 rounded-3 fw-bold">
                                Tiếp tục <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>

            <p class="mt-4 text-muted small">
                Một email xác nhận đã được gửi đến hộp thư của bạn.<br>
                Nếu có thắc mắc, vui lòng liên hệ <strong>Hotline: 1900 xxxx</strong>
            </p>

        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .fw-extrabold {
        font-weight: 800;
    }

    /* Hiệu ứng đường gạch đứt kiểu hóa đơn */
    .receipt-dashed-line {
        border-bottom: 2px dashed #dee2e6;
        padding-bottom: 1.5rem;
    }

    .card {
        background: #fff;
        position: relative;
    }

        /* Tạo hiệu ứng răng cưa giả ở mép thẻ (tùy chọn) */
        .card::after {
            content: "";
            position: absolute;
            bottom: -10px;
            left: 0;
            right: 0;
            height: 10px;
            background-image: radial-gradient(circle, transparent, transparent 50%, #fff 50%, #fff);
            background-size: 20px 20px;
            transform: rotate(180deg);
            display: none; /* Bật nếu muốn giao diện kiểu vé xé */
        }

    .btn {
        transition: all 0.3s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
        }
</style>
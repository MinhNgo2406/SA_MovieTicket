@model MovieTicket.Models.User

@{
    ViewData["Title"] = "My Profile";
}

<style>
    .profile-wrapper {
        max-width: 700px;
        margin: auto;
    }

    .profile-card {
        border-radius: 24px;
        overflow: hidden;
        background: #ffffff;
    }

    .profile-header {
        background: linear-gradient(135deg, #111827, #1f2937);
        padding: 40px 20px;
        text-align: center;
        color: white;
    }

    .profile-avatar {
        width: 95px;
        height: 95px;
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.2rem;
        margin: auto;
        margin-bottom: 15px;
        border: 3px solid rgba(255,255,255,0.2);
    }

    .profile-name {
        font-size: 1.5rem;
        font-weight: 700;
    }

    .profile-email {
        color: rgba(255,255,255,0.75);
        font-size: 0.95rem;
    }

    .profile-body {
        padding: 35px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        color: #374151;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #d1d5db;
    }

        .form-control:focus {
            border-color: #111827;
            box-shadow: none;
        }

    .readonly-input {
        background-color: #f3f4f6 !important;
        cursor: not-allowed;
    }

    .btn-save {
        background: #111827;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-save:hover {
            background: #1f2937;
            color: white;
        }

    .info-box {
        background: #f9fafb;
        border-radius: 14px;
        padding: 18px;
        margin-bottom: 25px;
    }

    .info-title {
        font-size: 0.9rem;
        color: #6b7280;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #111827;
    }
</style>

<div class="container mt-5 mb-5">

    <div class="profile-wrapper">

        <div class="card border-0 shadow profile-card">

            <!-- HEADER -->
            <div class="profile-header">

                <div class="profile-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>

                <div class="profile-name">
                    @Model.Name
                </div>

                <div class="profile-email">
                    @Model.Email
                </div>

            </div>

            <!-- BODY -->
            <div class="profile-body">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success rounded-3">
                        @TempData["Success"]
                    </div>
                }

                <!-- QUICK INFO -->
                <div class="row mb-4">

                    <div class="col-md-6">
                        <div class="info-box">
                            <div class="info-title">
                                Role
                            </div>

                            <div class="info-value">
                                @Model.Role
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="info-box">
                            <div class="info-title">
                                Phone Number
                            </div>

                            <div class="info-value">
                                @(Model.Phone ?? "Chưa cập nhật")
                            </div>
                        </div>
                    </div>

                </div>

                <!-- FORM -->
                <form asp-controller="Profile"
                      asp-action="UpdateProfile"
                      method="post">

                    <input type="hidden" asp-for="Id" />

                    <!-- NAME -->
                    <div class="mb-4">
                        <label class="form-label">
                            Full Name
                        </label>

                        <input asp-for="Name"
                               class="form-control" />
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-4">
                        <label class="form-label">
                            Email (Cannot Change)
                        </label>

                        <input asp-for="Email"
                               class="form-control readonly-input"
                               readonly />
                    </div>

                    <!-- PHONE -->
                    <div class="mb-4">
                        <label class="form-label">
                            Phone Number
                        </label>

                        <input asp-for="Phone"
                               class="form-control" />
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-4">
                        <label class="form-label">
                            New Password
                        </label>

                        <input type="password"
                               name="newPassword"
                               class="form-control"
                               placeholder="Nhập mật khẩu mới nếu muốn đổi" />
                    </div>

                    <button type="submit"
                            class="btn btn-save w-100">

                        Save Changes

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>